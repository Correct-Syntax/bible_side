    {
     "type": "char",
     "marker": "add",
     "content": [
      "#them"
     ]
    },
    ". It was an agreement ",
    {
     "type": "char",
     "marker": "add",
     "content": [
      "вүҲbased on respect"
     ]
    },
    ", and ",
    {
     "type": "char",
