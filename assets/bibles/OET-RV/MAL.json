  },
  {
   "type": "para",
   "marker": "p",
   "content": [
    {
     "type": "verse",
     "marker": "v",
     "number": "2",
     "sid": "MAL 1:2"
    },
    "вҖңI have loved you all,вҖқ says Yahweh, ",
    {
     "type": "char",
