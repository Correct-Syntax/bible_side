    {
     "type": "char",
     "marker": "add",
     "content": [
      "where Esaw lived"
     ]
    },
    " into a wastelandВҰ380199 and ",
    {
     "type": "char",
     "marker": "add",
     "content": [
      "given"
     ]
    },
