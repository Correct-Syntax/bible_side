      ]
    },
    {
      "type": "para",
      "marker": "toc2",
      "content": [
        "Habakkuk"
      ]
    },
    {
      "type": "para",
      "marker": "toc3",
      "content": [
        "HAB"
      ]
    },
    {
      "type": "para",
      "marker": "mt2",
